{
  "name": "drinking-counter",
  "version": "0.1.0",
  "private": true,
  "description": "一个本地 Windows 饮水提醒工具。",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --configLoader runner",
    "electron": "electron .",
    "start": "concurrently -k \"npm run dev\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "build": "vite build --configLoader runner",
    "dist": "npm run build && electron-builder --win dir"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "electron-store": "^8.2.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "local.whimsy.water",
    "productName": "饮水提醒",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "dir",
      "signAndEditExecutable": false
    }
  }
}
